---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/blog/TOC.astro';

interface Props {
  title: string;
  description?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, headings = [] } = Astro.props;
const hasTOC = headings.filter(h => h.depth >= 1 && h.depth <= 3).length > 0;
---

<style>
  .page-wrap {
    max-width: 90rem;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
  }
  .page-spacer {
    width: 13rem;
    flex-shrink: 0;
    padding-right: 1rem;
  }
  .page-content {
    flex: 1;
    min-width: 0;
    padding: 0 1.25rem;
  }
  .toc-aside {
    width: 13rem;
    flex-shrink: 0;
    padding-left: 1.25rem;
  }
  .toc-placeholder {
    width: 13rem;
    flex-shrink: 0;
  }
  @media (max-width: 1024px) {
    .toc-aside, .toc-placeholder { display: none; }
    .page-content { padding: 0 1rem; }
  }
  @media (max-width: 768px) {
    .page-wrap { padding: 1rem 0; }
    .page-spacer { display: none; }
    .page-content { padding: 0 1.25rem; }
  }
</style>

<BaseLayout title={title} description={description}>
  <div class="page-wrap">
    <div class="page-spacer"></div>
    <div class="page-content">
      <h1 style="font-size: 1.5rem; font-weight: 600; color: var(--text-primary); margin: 0 0 2rem;">{title}</h1>
      <div style="color: var(--text-primary);">
        <slot />
      </div>
    </div>
    {hasTOC ? (
      <aside class="toc-aside">
        <TOC headings={headings} />
      </aside>
    ) : (
      <div class="toc-placeholder" />
    )}
  </div>
</BaseLayout>
