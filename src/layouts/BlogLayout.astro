---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import TOC from '../components/blog/TOC.astro';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, currentSlug, headings = [] } = Astro.props;
const hasTOC = headings.filter(h => h.depth >= 2 && h.depth <= 3).length > 0;
---

<style>
  .layout-wrapper {
    max-width: 90rem;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    display: flex;
    gap: 0;
  }
  .sidebar-aside {
    width: 13rem;
    flex-shrink: 0;
    padding-right: 1rem;
  }
  .article-main {
    flex: 1;
    min-width: 0;
    padding: 0 2rem;
  }
  .toc-aside {
    width: 16rem;
    flex-shrink: 0;
    padding-left: 2rem;
  }
  .toc-placeholder {
    width: 16rem;
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .toc-aside, .toc-placeholder { display: none; }
    .article-main { padding: 0 1rem; }
  }

  @media (max-width: 768px) {
    .layout-wrapper { padding: 1.5rem 1.25rem; }
    .sidebar-aside { display: none; }
    .article-main { padding: 0; }
  }
</style>

<BaseLayout title={title} description={description}>
  <div class="layout-wrapper">

    <aside class="sidebar-aside">
      <Sidebar currentSlug={currentSlug} />
    </aside>

    <article class="article-main">
      <slot />
    </article>

    {hasTOC ? (
      <aside class="toc-aside">
        <TOC headings={headings} />
      </aside>
    ) : (
      <div class="toc-placeholder" />
    )}

  </div>
</BaseLayout>
