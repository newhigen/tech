---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import TOC from '../components/blog/TOC.astro';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, currentSlug, headings = [] } = Astro.props;
const hasTOC = headings.filter(h => h.depth >= 2 && h.depth <= 3).length > 0;

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const grouped = sorted.reduce<Record<string, typeof allPosts>>((acc, post) => {
  const cat = post.data.category;
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(post);
  return acc;
}, {});
const categories = Object.keys(grouped).sort();
const activeCategory = currentSlug ? sorted.find(p => p.id === currentSlug)?.data.category : null;

function formatRelativeDate(date: Date): { text: string; color: string } {
  const now = new Date();
  const diffMs = now.getTime() - new Date(date).getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays < 1) return { text: '오늘', color: 'rgb(217, 119, 6)' }; // amber
  if (diffDays < 7) return { text: `${diffDays}일 전`, color: 'rgb(192, 132, 16)' }; // orange-brown
  if (diffDays < 31) return { text: `${Math.floor(diffDays / 7)}주 전`, color: 'rgb(120, 113, 108)' }; // warm gray
  if (diffDays < 365) return { text: `${Math.floor(diffDays / 30)}달 전`, color: 'rgb(107, 114, 128)' }; // slate
  return { text: `${Math.floor(diffDays / 365)}년 전`, color: 'rgb(100, 116, 139)' }; // slate-blue
}
---

<style>
  .layout-wrapper {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    gap: 0;
  }
  .sidebar-aside {
    width: 13rem;
    flex-shrink: 0;
    padding-right: 1rem;
  }
  .article-main {
    flex: 1;
    min-width: 0;
    padding: 0 1.25rem;
  }
  .toc-aside {
    width: 13rem;
    flex-shrink: 0;
    padding-left: 1.25rem;
  }
  .toc-placeholder {
    width: 13rem;
    flex-shrink: 0;
  }

  [data-drawer-cat-toggle]:hover {
    color: var(--text-primary) !important;
  }

  .drawer-post-link {
    display: flex;
    align-items: center;
    padding: 0.25rem 0.25rem;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    text-decoration: none;
  }
  .drawer-post-link:hover {
    color: var(--text-primary);
    opacity: 1;
  }
  .drawer-post-link.active-post {
    color: var(--text-primary);
    font-weight: 500;
  }

  @media (max-width: 1024px) {
    .toc-aside, .toc-placeholder { display: none; }
    .article-main { padding: 0 1rem; }
  }

  @media (max-width: 768px) {
    .layout-wrapper { padding: 1rem 0; }
    .sidebar-aside { display: none; }
    .article-main { padding: 0 1.25rem; }
  }
</style>

<BaseLayout title={title} description={description}>

  <!-- 드로워 오버레이 -->
  <div class="drawer-overlay" id="drawer-overlay"></div>

  <!-- 드로워 패널 -->
  <div class="drawer-panel" id="drawer-panel">
    <div class="drawer-header">
      <span class="drawer-title">Categories</span>
      <button class="drawer-close" id="drawer-close" aria-label="Close">✕</button>
    </div>
    {categories.map(cat => {
      const isOpen = activeCategory === cat;
      const catId = cat.replace(/\s+/g, '-').toLowerCase();
      return (
        <div key={catId} style="margin-bottom: 0.375rem;">
          <button
            data-drawer-cat-toggle={catId}
            aria-expanded={String(isOpen)}
            style={`
              display: flex;
              align-items: center;
              justify-content: space-between;
              width: 100%;
              padding: 0.375rem 0.25rem;
              border: none;
              background: none;
              cursor: pointer;
              font-size: 0.8125rem;
              font-weight: 500;
              color: var(--text-secondary);
              text-align: left;
            `}
          >
            {cat}
            <svg
              data-drawer-cat-arrow={catId}
              width="10" height="10" viewBox="0 0 10 10" fill="currentColor"
              style={`transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); transform: rotate(${isOpen ? '90deg' : '0deg'}); opacity: 0.5; flex-shrink: 0;`}
            >
              <path d="M3 2l4 3-4 3V2z"/>
            </svg>
          </button>

          <div
            id={`drawer-cat-${catId}`}
            style={`list-style: none; margin: 0; padding: 0 0 0 0.5rem; overflow: hidden; max-height: ${isOpen ? '600px' : '0'}; transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);`}
          >
            {grouped[cat].map(post => {
              const { text: relDate, color: dateColor } = formatRelativeDate(new Date(post.data.pubDate));
              return (
                <a
                  href={`/${post.id}`}
                  class={`drawer-post-link${currentSlug === post.id ? ' active-post' : ''}`}
                >
                  <span style="max-width: 9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{post.data.title}</span>
                  <span style={`font-size: 0.75rem; color: ${dateColor}; opacity: 0.65; flex-shrink: 0; margin-left: 0.25rem;`}>{relDate}</span>
                </a>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>

  <!-- 모바일 드로워 트리거 -->
  <div class="drawer-trigger">
    <button id="drawer-open" aria-label="Open navigation" style="background: none; border: 1px solid var(--border); border-radius: 6px; cursor: pointer; color: var(--text-secondary); padding: 0.3rem 0.625rem; display: flex; align-items: center; gap: 0.375rem; transition: border-color 0.15s ease, color 0.15s ease;">
      <span style="font-size: 0.8125rem;">›</span>
      <span style="font-size: 0.8125rem;">{activeCategory ?? 'Categories'}</span>
    </button>
  </div>

  <div class="layout-wrapper">
    <aside class="sidebar-aside">
      <Sidebar currentSlug={currentSlug} />
    </aside>

    <article class="article-main">
      <slot />
    </article>

    {hasTOC ? (
      <aside class="toc-aside">
        <TOC headings={headings} />
      </aside>
    ) : (
      <div class="toc-placeholder" />
    )}
  </div>

</BaseLayout>

<script is:inline>
  function initDrawer() {
    const openBtn = document.getElementById('drawer-open');
    const closeBtn = document.getElementById('drawer-close');
    const overlay = document.getElementById('drawer-overlay');
    const panel = document.getElementById('drawer-panel');
    if (!openBtn || !closeBtn || !overlay || !panel) return;

    function openDrawer() {
      panel.classList.add('open');
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      panel.classList.remove('open');
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }

    openBtn.addEventListener('click', openDrawer);
    closeBtn.addEventListener('click', closeDrawer);
    overlay.addEventListener('click', closeDrawer);

    // Category toggle functionality
    const catToggles = panel.querySelectorAll('[data-drawer-cat-toggle]');
    catToggles.forEach(btn => {
      btn.addEventListener('click', () => {
        const catId = btn.getAttribute('data-drawer-cat-toggle');
        const catContent = document.getElementById(`drawer-cat-${catId}`);
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        btn.setAttribute('aria-expanded', !isOpen);
        catContent.style.maxHeight = !isOpen ? '600px' : '0';

        const arrow = document.querySelector(`[data-drawer-cat-arrow="${catId}"]`);
        if (arrow) {
          arrow.style.transform = !isOpen ? 'rotate(90deg)' : 'rotate(0deg)';
        }
      });
    });
  }
  document.addEventListener('astro:page-load', initDrawer);
</script>

<script>
  import mermaid from 'mermaid';

  function renderMermaid() {
    const blocks = document.querySelectorAll('pre[data-language="mermaid"] code');
    if (!blocks.length) return;

    mermaid.initialize({ startOnLoad: false, theme: 'neutral' });

    blocks.forEach(async (block, i) => {
      const code = block.textContent ?? '';
      const id = `mermaid-${i}`;
      const { svg } = await mermaid.render(id, code);
      const wrapper = document.createElement('div');
      wrapper.innerHTML = svg;
      block.closest('pre')?.replaceWith(wrapper);
    });
  }

  document.addEventListener('astro:page-load', renderMermaid);
</script>
