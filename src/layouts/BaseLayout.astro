---
import { ClientRouter } from 'astro:transitions';
import { getCollection } from 'astro:content';
import '../styles/global.css';
import '../styles/post.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "newhigen's tech blog" } = Astro.props;

const allPosts = await getCollection('blog');
const sorted = allPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
const grouped = sorted.reduce<Record<string, typeof allPosts>>((acc, post) => {
  const cat = post.data.category;
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(post);
  return acc;
}, {});
const categories = Object.keys(grouped).sort();

function formatRelativeDate(date: Date): { text: string; color: string } {
  const now = new Date();
  const diffMs = now.getTime() - new Date(date).getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays < 1) return { text: '오늘', color: 'rgb(217, 119, 6)' };
  if (diffDays < 7) return { text: `${diffDays}일 전`, color: 'rgb(192, 132, 16)' };
  if (diffDays < 31) return { text: `${Math.floor(diffDays / 7)}주 전`, color: 'rgb(120, 113, 108)' };
  if (diffDays < 365) return { text: `${Math.floor(diffDays / 30)}달 전`, color: 'rgb(107, 114, 128)' };
  return { text: `${Math.floor(diffDays / 365)}년 전`, color: 'rgb(100, 116, 139)' };
}
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta name="google-site-verification" content="VLi2Q2MCHzrYvm80ry_lSLF1AueEC0iJDzkSxVWIqY8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <ClientRouter />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QHJJSW8L6X"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QHJJSW8L6X');
      document.addEventListener('astro:page-load', () => {
        gtag('config', 'G-QHJJSW8L6X', { page_path: window.location.pathname });
      });
    </script>

    <script is:inline>
      function applyTheme() {
        const theme = localStorage.getItem('theme') ||
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);

      function updateThemeIcons() {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const isDark = document.documentElement.classList.contains('dark');
        const sun = btn.querySelector('.sun-icon');
        const moon = btn.querySelector('.moon-icon');
        if (sun) sun.style.display = isDark ? 'none' : 'block';
        if (moon) moon.style.display = isDark ? 'block' : 'none';
      }
      document.addEventListener('astro:page-load', updateThemeIcons);

      document.addEventListener('click', function(e) {
        if (e.target.closest('#theme-toggle')) {
          const nowDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', nowDark ? 'dark' : 'light');
          updateThemeIcons();
        }
      });
    </script>
  </head>
  <body>
    <Header />

    <!-- 드로워 오버레이 -->
    <div class="drawer-overlay" id="drawer-overlay"></div>

    <!-- 드로워 패널 -->
    <div class="drawer-panel" id="drawer-panel">
      <div class="drawer-header">
        <span class="drawer-title">Categories</span>
        <button class="drawer-close" id="drawer-close" aria-label="Close">✕</button>
      </div>
      {categories.map(cat => {
        const catId = cat.replace(/\s+/g, '-').toLowerCase();
        return (
          <div key={catId} style="margin-bottom: 0.375rem;">
            <button
              data-drawer-cat-toggle={catId}
              aria-expanded="false"
              style={`
                display: flex;
                align-items: center;
                justify-content: space-between;
                width: 100%;
                padding: 0.375rem 0.25rem;
                border: none;
                background: none;
                cursor: pointer;
                font-size: 0.8125rem;
                font-weight: 500;
                color: var(--text-secondary);
                text-align: left;
              `}
            >
              {cat}
              <svg
                data-drawer-cat-arrow={catId}
                width="10" height="10" viewBox="0 0 10 10" fill="currentColor"
                style={`transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); opacity: 0.5; flex-shrink: 0;`}
              >
                <path d="M3 2l4 3-4 3V2z"/>
              </svg>
            </button>

            <div
              id={`drawer-cat-${catId}`}
              style={`list-style: none; margin: 0; padding: 0 0 0 0.5rem; overflow: hidden; max-height: 0; transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);`}
            >
              {grouped[cat].map(post => {
                const { text: relDate, color: dateColor } = formatRelativeDate(new Date(post.data.pubDate));
                return (
                  <a
                    href={`/${post.id}`}
                    class="drawer-post-link"
                    style="display: flex; align-items: center; padding: 0.25rem 0.25rem; font-size: 0.8125rem; color: var(--text-secondary); text-decoration: none;"
                  >
                    <span style="max-width: 9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{post.data.title}</span>
                    <span style={`font-size: 0.75rem; color: ${dateColor}; opacity: 0.65; flex-shrink: 0; margin-left: 0.25rem;`}>{relDate}</span>
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

    <!-- 모바일 드로워 트리거 -->
    <div class="drawer-trigger">
      <button id="drawer-open" aria-label="Open navigation" style="background: none; border: 1px solid var(--border); border-radius: 6px; cursor: pointer; color: var(--text-secondary); padding: 0.3rem 0.625rem; display: flex; align-items: center; gap: 0.375rem; transition: border-color 0.15s ease, color 0.15s ease;">
        <span style="font-size: 0.8125rem;">›</span>
        <span style="font-size: 0.8125rem;">Categories</span>
      </button>
    </div>

    <main>
      <slot />
    </main>
    <Footer />

    <script is:inline>
      function initDrawer() {
        const openBtn = document.getElementById('drawer-open');
        const closeBtn = document.getElementById('drawer-close');
        const overlay = document.getElementById('drawer-overlay');
        const panel = document.getElementById('drawer-panel');
        if (!openBtn || !closeBtn || !overlay || !panel) return;

        function openDrawer() {
          panel.classList.add('open');
          overlay.classList.add('open');
          document.body.style.overflow = 'hidden';
        }
        function closeDrawer() {
          panel.classList.remove('open');
          overlay.classList.remove('open');
          document.body.style.overflow = '';
        }

        openBtn.addEventListener('click', openDrawer);
        closeBtn.addEventListener('click', closeDrawer);
        overlay.addEventListener('click', closeDrawer);

        // Category toggle functionality
        const catToggles = panel.querySelectorAll('[data-drawer-cat-toggle]');
        catToggles.forEach(btn => {
          btn.addEventListener('click', () => {
            const catId = btn.getAttribute('data-drawer-cat-toggle');
            const catContent = document.getElementById(`drawer-cat-${catId}`);
            const isOpen = btn.getAttribute('aria-expanded') === 'true';

            btn.setAttribute('aria-expanded', !isOpen);
            catContent.style.maxHeight = !isOpen ? '600px' : '0';

            const arrow = document.querySelector(`[data-drawer-cat-arrow="${catId}"]`);
            if (arrow) {
              arrow.style.transform = !isOpen ? 'rotate(90deg)' : 'rotate(0deg)';
            }
          });
        });
      }
      document.addEventListener('astro:page-load', initDrawer);
    </script>
  </body>
</html>
