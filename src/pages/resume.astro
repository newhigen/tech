---
import PageLayout from '../layouts/PageLayout.astro';

function calcDuration(startStr: string, endStr?: string): string {
  const [sy, sm] = startStr.split('.').map(Number);
  let ey: number, em: number;
  if (!endStr) {
    const now = new Date();
    ey = now.getFullYear();
    em = now.getMonth() + 1;
  } else {
    [ey, em] = endStr.split('.').map(Number);
  }
  const months = (ey - sy) * 12 + (em - sm) + 1;
  const years = Math.floor(months / 12);
  const rem = months % 12;
  if (years === 0) return `${months}개월`;
  if (rem === 0) return `${years}년`;
  return `${years}년 ${rem}개월`;
}

const vunoDuration = calcDuration('2022.3');
const koreDuration = calcDuration('2019.6', '2022.2');
