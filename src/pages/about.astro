---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="About" description="About me">
  <p class="text-lg text-slate-600 dark:text-slate-400 mb-6">
    Hi, I'm newhigen. Welcome to my tech blog!
  </p>

  <h2 class="text-2xl font-bold mt-8 mb-4">Background</h2>
  <p class="text-slate-700 dark:text-slate-300 mb-4">
    I'm a software developer passionate about building things on the web. I enjoy exploring new technologies, solving complex problems, and sharing what I've learned.
  </p>

  <h2 class="text-2xl font-bold mt-8 mb-4">Interests</h2>
  <ul class="list-disc list-inside text-slate-700 dark:text-slate-300 space-y-2">
    <li>Web Development (Frontend & Backend)</li>
    <li>System Design & Architecture</li>
    <li>Open Source</li>
    <li>Performance & Optimization</li>
  </ul>

  <h2 class="text-2xl font-bold mt-8 mb-4">Get in Touch</h2>
  <p class="text-slate-700 dark:text-slate-300">
    Feel free to reach out on GitHub or Twitter if you'd like to connect!
  </p>
</PageLayout>
