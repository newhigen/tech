---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: any;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = new Date(post.data.pubDate).toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdatedDate = post.data.updatedDate
  ? new Date(post.data.updatedDate).toLocaleDateString('ko-KR', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BlogLayout title={post.data.title} description={post.data.description} currentSlug={post.id} headings={headings}>
  <div>
    <header style="margin-bottom: 1rem; padding-bottom: 0.75rem;">
      <h1 class="post-title">{post.data.title}</h1>
      <p style="font-size: 0.8125rem; color: var(--text-tertiary); margin: 0 0 0.75rem;">
        {formattedDate}
        {formattedUpdatedDate && <> · Updated {formattedUpdatedDate}</>}
      </p>
      {post.data.tags?.length > 0 && (
        <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
          {post.data.tags.map((tag: string) => (
            <a href={`/tags/${encodeURIComponent(tag)}`} class="tag-link">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <article style="color: var(--text-primary); line-height: 1.75;">
      <Content />
    </article>
  </div>
</BlogLayout>

<style>
  .tag-link {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    background: var(--code-bg);
    color: var(--text-tertiary);
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .tag-link:hover {
    color: var(--text-primary);
    background: var(--border);
  }

  .post-title {
    font-size: 2rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.5rem;
    }
  }
</style>
