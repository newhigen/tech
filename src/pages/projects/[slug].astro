---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

interface Props {
  project: any;
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<PageLayout title={project.data.title} description={project.data.description}>
  <div class="mb-6">
    {project.data.link && (
      <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline mr-4">
        Visit →
      </a>
    )}
    {project.data.github && (
      <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="text-blue-600 dark:text-blue-400 hover:underline">
        GitHub →
      </a>
    )}
  </div>

  <div class="mb-6">
    {project.data.tags?.map((tag: string) => (
      <span class="inline-block px-2 py-1 mr-2 mb-2 text-xs rounded bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
        {tag}
      </span>
    ))}
  </div>

  <article class="prose dark:prose-invert max-w-none">
    <Content />
  </article>
</PageLayout>
