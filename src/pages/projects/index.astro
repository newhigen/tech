---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/project/ProjectCard.astro';

const allProjects = await getCollection('projects');
---

<BaseLayout title="Projects - newhigen" description="My projects and portfolio">
  <div class="page-container" style="max-width: 52rem; margin: 0 auto; padding: 3rem 2rem;">
    <h1 style="font-size: 1.5rem; font-weight: 600; color: var(--text-primary); margin: 0 0 2rem;">Projects</h1>
    <div>
      {allProjects.map(project => (
        <ProjectCard
          title={project.data.title}
          slug={project.id}
          description={project.data.description}
          link={project.data.link}
          github={project.data.github}
          tags={project.data.tags}
        />
      ))}
      {allProjects.length === 0 && (
        <p style="color: var(--text-secondary);">No projects yet.</p>
      )}
    </div>
  </div>
</BaseLayout>
