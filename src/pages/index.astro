---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/blog/PostCard.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 5);
---

<BaseLayout title="tech.sungduk">
  <div style="max-width: 52rem; margin: 0 auto; padding: 2.5rem 2rem;">
    <section style="margin-bottom: 2.5rem;">
      <h1 style="font-size: 1.5rem; font-weight: 600; color: var(--text-primary); margin: 0 0 0.5rem;">tech.sungduk</h1>
      <p style="font-size: 0.9375rem; color: var(--text-secondary); margin: 0;">
        ML Engineer. 반복을 없애고 팀이 잘 돌아가는 구조를 좋아합니다. 읽고 쓰는 것도 — <a href="https://sungd.uk" style="color: var(--text-secondary); text-decoration: underline; text-underline-offset: 3px;">sungd.uk</a>
      </p>
    </section>

    <section>
      <h2 style="font-size: 0.8125rem; font-weight: 500; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 0;">
        Recent Posts
      </h2>
      <div>
        {recentPosts.map(post => (
          <PostCard
            title={post.data.title}
            slug={post.id}
            description={post.data.description}
            pubDate={post.data.pubDate}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
      <div style="margin-top: 1.5rem;">
        <a href="/tech" style="font-size: 0.875rem; color: var(--text-tertiary);">
          All →
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
