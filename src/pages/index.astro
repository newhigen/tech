---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/layout/Sidebar.astro';
import PostCard from '../components/blog/PostCard.astro';
import ProjectCard from '../components/project/ProjectCard.astro';

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 5);

const allProjects = await getCollection('projects');
function periodToNum(p?: string) {
  if (!p) return 0;
  const m = p.match(/(\d{4})\.(\d{2})/);
  return m ? parseInt(m[1]) * 100 + parseInt(m[2]) : 0;
}
const sortedProjects = [...allProjects].sort(
  (a, b) => periodToNum(b.data.period) - periodToNum(a.data.period)
);
---

<style>
  .layout-wrapper {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    gap: 0;
  }
  .sidebar-aside {
    width: 13rem;
    flex-shrink: 0;
    padding-right: 1rem;
  }
  .home-main {
    flex: 1;
    min-width: 0;
    max-width: 52rem;
    padding: 0 1.25rem;
  }
  .home-section {
    margin-bottom: 2.5rem;
  }
  .home-section:first-child {
    margin-bottom: 2.5rem;
  }
  .all-posts-list {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .all-posts-list.open {
    max-height: 2000px;
  }

  @media (max-width: 768px) {
    .layout-wrapper { padding: 1rem 0; }
    .sidebar-aside { display: none; }
    .home-main { padding: 0 1.25rem; }
  }
</style>

<BaseLayout title="tech.sungduk">

  <div class="layout-wrapper">
    <aside class="sidebar-aside">
      <Sidebar />
    </aside>

    <div class="home-main">
      <section class="home-section">
        <p style="font-size: 0.9375rem; color: var(--text-secondary); margin: 0;">
          기술에 대해 쓰고 기록합니다.
        </p>
      </section>

      <section class="home-section">
        <h2 style="font-size: 0.8125rem; font-weight: 500; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 1rem;">
          Recent Posts
        </h2>
        <div class="post-list">
          {recentPosts.map(post => (
            <PostCard
              title={post.data.title}
              slug={post.id}
              description={post.data.description}
              pubDate={post.data.pubDate}
              category={post.data.category}
              tags={post.data.tags}
              compact
            />
          ))}
        </div>
        <div style="margin-top: 1.5rem;">
          <button
            id="all-posts-btn"
            style="font-size: 0.875rem; color: var(--text-tertiary); background: none; border: none; cursor: pointer; padding: 0;"
          >
            All →
          </button>
        </div>

        <div class="all-posts-list" id="all-posts-list">
          <div style="margin-top: 1.5rem;">
            {allPosts
              .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
              .map(post => (
                <PostCard
                  title={post.data.title}
                  slug={post.id}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  category={post.data.category}
                  tags={post.data.tags}
                  compact
                />
              ))}
          </div>
        </div>
      </section>

      <section class="home-section">
        <h2 style="font-size: 0.8125rem; font-weight: 500; color: var(--text-tertiary); text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 1rem;">
          Projects
        </h2>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          {sortedProjects.map(project => (
            <ProjectCard
              title={project.data.title}
              slug={project.id}
              description={project.data.description}
              link={project.data.link}
              link2={project.data.link2}
              github={project.data.github}
              tags={project.data.tags}
              period={project.data.period}
              icon={project.data.icon}
              compact
            />
          ))}
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const openBtn = document.getElementById('all-posts-btn');
      const allPostsList = document.getElementById('all-posts-list');

      if (!openBtn || !allPostsList) return;

      openBtn.addEventListener('click', () => {
        allPostsList.classList.toggle('open');
      });
    });
  </script>
</BaseLayout>
