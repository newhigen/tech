---
import ThemeToggle from '../ui/ThemeToggle.astro';
---

<style>
  .nav-link {
    color: var(--text-secondary);
  }
  .nav-link:hover {
    color: var(--text-primary);
    opacity: 1;
  }
</style>

<header style="border-bottom: 1px solid var(--border); background-color: var(--bg);">
  <nav style="max-width: 90rem; margin: 0 auto; padding: 1rem 2rem; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;">
    <a href="/" style="font-size: 1rem; font-weight: 600; color: var(--text-primary);">
      newhigen
    </a>
    <ul style="display: flex; gap: 1.5rem; list-style: none; margin: 0; padding: 0; font-size: 0.875rem;">
      <li><a href="/tech" class="nav-link">Tech</a></li>
      <li><a href="/projects" class="nav-link">Projects</a></li>
      <li><a href="/about" class="nav-link">About</a></li>
      <li><a href="/resume" class="nav-link">Resume</a></li>
    </ul>
    <div style="display: flex; justify-content: flex-end;">
      <ThemeToggle />
    </div>
  </nav>
</header>
