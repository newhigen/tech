---
import ThemeToggle from '../ui/ThemeToggle.astro';
---

<style>
  .nav-link {
    color: var(--text-secondary);
  }
  .nav-link:hover {
    color: var(--text-primary);
    opacity: 1;
  }
  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-secondary);
    padding: 0.25rem;
    line-height: 1;
  }
  .mobile-menu {
    flex-direction: column;
    padding: 0.75rem 1.25rem 1rem;
    gap: 0.875rem;
    border-top: 1px solid var(--border);
  }
  .mobile-menu a {
    font-size: 0.9375rem;
    color: var(--text-secondary);
  }

  @media (max-width: 640px) {
    .desktop-nav { display: none !important; }
    .hamburger { display: block; }
  }
</style>

<header style="background-color: var(--bg);">
  <nav style="max-width: 90rem; margin: 0 auto; padding: 1rem 1.25rem; display: flex; align-items: center; justify-content: space-between;">
    <a href="/" style="font-size: 1rem; font-weight: 600; color: var(--text-primary);">
      tech.sungduk
    </a>
    <ul class="desktop-nav" style="display: flex; gap: 1.5rem; list-style: none; margin: 0; padding: 0; font-size: 0.875rem;">
      <li><a href="/tech" class="nav-link">Tech</a></li>
      <li><a href="/projects" class="nav-link">Projects</a></li>
      <li><a href="/about" class="nav-link">About</a></li>
      <li><a href="/resume" class="nav-link">Resume</a></li>
    </ul>
    <div style="display: flex; align-items: center; gap: 0.75rem;">
      <ThemeToggle />
      <button class="hamburger" id="hamburger-btn" aria-label="메뉴">
        <svg id="icon-menu" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M3 5h14a1 1 0 010 2H3a1 1 0 010-2zm0 4h14a1 1 0 010 2H3a1 1 0 010-2zm0 4h14a1 1 0 010 2H3a1 1 0 010-2z"/>
        </svg>
        <svg id="icon-close" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" style="display:none;">
          <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"/>
        </svg>
      </button>
    </div>
  </nav>
  <div class="mobile-menu" id="mobile-menu" style="display: none;">
    <a href="/tech" class="nav-link">Tech</a>
    <a href="/projects" class="nav-link">Projects</a>
    <a href="/about" class="nav-link">About</a>
    <a href="/resume" class="nav-link">Resume</a>
  </div>
</header>

<script is:inline>
  function initHamburger() {
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('mobile-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const isOpen = menu.style.display === 'flex';
      menu.style.display = isOpen ? 'none' : 'flex';
      menu.style.flexDirection = 'column';
      iconMenu.style.display = isOpen ? 'block' : 'none';
      iconClose.style.display = isOpen ? 'none' : 'block';
    });
  }
  document.addEventListener('astro:page-load', initHamburger);
</script>
