---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;

const allPosts = await getCollection('blog');
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const grouped = sorted.reduce<Record<string, typeof allPosts>>((acc, post) => {
  const cat = post.data.category;
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(post);
  return acc;
}, {});

const categories = Object.keys(grouped).sort();

const activeCategory = currentSlug
  ? sorted.find(p => p.id === currentSlug)?.data.category
  : null;

function formatRelativeDate(date: Date): { text: string; color: string } {
  const now = new Date();
  const diffMs = now.getTime() - new Date(date).getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  if (diffDays < 1) return { text: '오늘', color: 'rgb(217, 119, 6)' }; // amber
  if (diffDays < 7) return { text: `${diffDays}일 전`, color: 'rgb(192, 132, 16)' }; // orange-brown
  if (diffDays < 31) return { text: `${Math.floor(diffDays / 7)}주 전`, color: 'rgb(120, 113, 108)' }; // warm gray
  if (diffDays < 365) return { text: `${Math.floor(diffDays / 30)}달 전`, color: 'rgb(107, 114, 128)' }; // slate
  return { text: `${Math.floor(diffDays / 365)}년 전`, color: 'rgb(100, 116, 139)' }; // slate-blue
}
---

<style>
  .cat-btn:hover {
    color: var(--text-primary) !important;
    opacity: 1 !important;
  }
  .post-link:hover {
    color: var(--text-primary) !important;
    opacity: 1;
  }
</style>

<nav style="position: sticky; top: 1.5rem;">
  <div style="display: flex; flex-direction: column; gap: 0.125rem;">
    {categories.map(cat => {
      const isOpen = activeCategory === cat;
      const catId = cat.replace(/\s+/g, '-').toLowerCase();
      return (
        <div style="margin-bottom: 0.25rem;">
          <button
            data-cat-toggle={catId}
            aria-expanded={String(isOpen)}
            class="cat-btn"
            style={`
              display: flex;
              align-items: center;
              justify-content: space-between;
              width: 100%;
              padding: 0.5rem 0.25rem 0.25rem;
              border: none;
              background: none;
              cursor: pointer;
              font-size: 0.875rem;
              font-weight: 500;
              color: var(--text-tertiary);
              letter-spacing: 0.02em;
              text-align: left;
            `}
          >
            {cat}
            <svg
              data-cat-arrow={catId}
              width="10" height="10" viewBox="0 0 10 10" fill="currentColor"
              style={`transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1); transform: rotate(${isOpen ? '90deg' : '0deg'}); opacity: 0.5; flex-shrink: 0;`}
            >
              <path d="M3 2l4 3-4 3V2z"/>
            </svg>
          </button>

          <ul
            id={`cat-${catId}`}
            style={`list-style: none; margin: 0; padding: 0; overflow: hidden; max-height: ${isOpen ? '600px' : '0'}; transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);`}
          >
            {grouped[cat].map(post => {
              const isActive = currentSlug === post.id;
              const { text: relDate, color: dateColor } = formatRelativeDate(new Date(post.data.pubDate));
              return (
                <li>
                  <a
                    href={`/${post.id}`}
                    class="post-link"
                    style={`
                      display: inline-flex;
                      align-items: center;
                      padding: 0.25rem 0.25rem 0.25rem 0.75rem;
                      font-size: 0.8125rem;
                      line-height: 1.6;
                      color: ${isActive ? 'var(--text-primary)' : 'var(--text-tertiary)'};
                      font-weight: ${isActive ? '500' : '400'};
                      transition: color 0.15s ease;
                      white-space: nowrap;
                      overflow: hidden;
                    `}
                  >
                    <span style="max-width: 9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{post.data.title}</span>
                    <span style={`font-size: 0.75rem; color: ${dateColor}; opacity: 0.65; margin-left: 0.25rem; flex-shrink: 0;`}>{relDate}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      );
    })}
  </div>
</nav>

<script is:inline>
  function initSidebar() {
    document.querySelectorAll('[data-cat-toggle]').forEach(btn => {
      btn.addEventListener('click', () => {
        const catId = btn.getAttribute('data-cat-toggle');
        const list = document.getElementById('cat-' + catId);
        const arrow = document.querySelector('[data-cat-arrow="' + catId + '"]');
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Reset color for all other categories
        document.querySelectorAll('[data-cat-toggle]').forEach(otherBtn => {
          if (otherBtn !== btn) {
            otherBtn.style.color = 'var(--text-secondary)';
          }
        });

        btn.setAttribute('aria-expanded', String(!isOpen));
        list.style.maxHeight = isOpen ? '0' : '600px';
        arrow.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(90deg)';
        btn.style.color = isOpen ? 'var(--text-secondary)' : 'var(--text-primary)';
      });
    });
  }

  document.addEventListener('astro:page-load', initSidebar);
</script>
