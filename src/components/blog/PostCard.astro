---
interface Props {
  title: string;
  slug: string;
  description: string;
  pubDate: Date;
  category: string;
  tags?: string[];
}

const { title, slug, description, pubDate, category, tags = [] } = Astro.props;

const formattedDate = new Date(pubDate).toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="border border-slate-200 dark:border-slate-800 rounded-lg p-6 hover:shadow-md dark:hover:shadow-md dark:shadow-slate-900 transition-shadow">
  <div class="flex items-start justify-between gap-4 mb-3">
    <div>
      <a href={`/blog/${slug}`} class="text-lg font-semibold text-slate-900 dark:text-slate-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        {title}
      </a>
    </div>
  </div>

  <p class="text-sm text-slate-600 dark:text-slate-400 mb-3">
    {formattedDate} · <span class="text-slate-500 dark:text-slate-500">{category}</span>
  </p>

  <p class="text-slate-700 dark:text-slate-300 mb-4 line-clamp-3">
    {description}
  </p>

  <div class="flex gap-2 flex-wrap">
    {tags.map(tag => (
      <span class="inline-block px-2 py-1 text-xs rounded bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
        {tag}
      </span>
    ))}
  </div>
</article>
