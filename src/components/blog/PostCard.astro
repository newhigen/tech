---
interface Props {
  title: string;
  slug: string;
  description: string;
  pubDate: Date;
  category: string;
  tags?: string[];
  compact?: boolean;
}

const { title, slug, description, pubDate, category, compact = false } = Astro.props;

function formatDate(date: Date): { text: string; color: string } {
  const dow = '일월화수목금토'[date.getDay()];
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

  let text = '';
  let color = '';

  if (diffDays < 1) {
    text = `오늘 (${dow})`;
    color = 'rgb(217, 119, 6)'; // amber
  } else if (diffDays < 7) {
    text = `${diffDays}일 전 (${dow})`;
    color = 'rgb(192, 132, 16)'; // orange-brown
  } else if (diffDays < 31) {
    text = `${Math.floor(diffDays / 7)}주 전 (${dow})`;
    color = 'rgb(120, 113, 108)'; // warm gray
  } else if (diffDays < 365) {
    text = `${Math.floor(diffDays / 30)}달 전 (${dow})`;
    color = 'rgb(107, 114, 128)'; // slate
  } else {
    text = `${date.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })} (${dow})`;
    color = 'rgb(100, 116, 139)'; // slate-blue
  }

  return { text, color };
}

const { text: formattedDate, color: dateColor } = formatDate(new Date(pubDate));
---

<style>
  .post-card {
    padding: 0.625rem 0;
  }
  .post-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.2rem;
  }
  .post-title {
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 1;
    min-width: 0;
    transition: opacity 0.15s ease;
  }
  .post-title:hover {
    opacity: 0.6;
  }
  .dotted-divider {
    flex: 1 1 2rem;
    min-width: 2rem;
    max-width: 100%;
    overflow: hidden;
    text-align: end;
    letter-spacing: 5px;
    height: 1.5rem;
    color: var(--text-tertiary);
    opacity: 0.5;
    pointer-events: none;
    white-space: nowrap;
    line-height: 1.5rem;
  }
  .post-date {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .post-meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .post-category {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .post-desc {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* compact */
  .compact-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0;
  }
  .compact-title {
    text-decoration: none;
    font-size: 0.875rem;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 1;
    min-width: 0;
  }
</style>

{compact ? (
  <div class="compact-row">
    <a href={`/${slug}`} class="compact-title">{title}</a>
    <span class="dotted-divider">·····························································································································································</span>
    <span class="post-date" style={`color: ${dateColor}`}>{formattedDate}</span>
  </div>
) : (
  <article class="post-card">
    <div class="post-row">
      <a href={`/${slug}`} class="post-title">{title}</a>
      <span class="dotted-divider">·····························································································································································</span>
      <span class="post-date" style={`color: ${dateColor}`}>{formattedDate}</span>
    </div>
    <div class="post-meta">
      <span class="post-category">{category}</span>
      <p class="post-desc">{description}</p>
    </div>
  </article>
)}
