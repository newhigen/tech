---
interface Props {
  title: string;
  slug: string;
  description: string;
  link?: string;
  github?: string;
  tags?: string[];
  period?: string;
}

const { title, description, link, github, tags = [], period } = Astro.props;
const domain = link ? new URL(link).hostname : null;
---

<article class="project-card">
  <div class="card-top">
    <div class="title-row">
      <h2 class="title">
        {title}
        {domain && <span class="domain">· {domain}</span>}
      </h2>
      {period && <span class="period">{period}</span>}
    </div>
    <div class="links">
      {github && (
        <a href={github} target="_blank" rel="noopener noreferrer" class="ext-link">GitHub →</a>
      )}
    </div>
  </div>
  <p class="description">{description}</p>
  {tags.length > 0 && (
    <div class="tags">
      {tags.map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  )}
</article>

<style>
  .project-card {
    padding: 1rem 1.125rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--code-bg);
    opacity: 0.8;
    transition: border-color 0.15s ease, background-color 0.15s ease, opacity 0.15s ease;
  }

  .project-card:hover {
    border-color: var(--text-tertiary);
    opacity: 1;
  }

  .card-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.3rem;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
    min-width: 0;
  }

  .title {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-primary);
    margin: 0;
    padding: 0;
    border: none;
    white-space: nowrap;
  }

  .domain {
    font-size: 0.8125rem;
    font-weight: 400;
    color: var(--text-tertiary);
    margin-left: 0.25rem;
  }

  .period {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .links {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .ext-link {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    text-decoration: none;
    white-space: nowrap;
  }

  .ext-link:hover {
    color: var(--text-secondary);
    opacity: 1;
  }

  .description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0 0 0.5rem;
    line-height: 1.55;
  }

  .tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.725rem;
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--text-tertiary);
  }
</style>
