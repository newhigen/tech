---
interface Props {
  title: string;
  slug: string;
  description: string;
  link?: string;
  github?: string;
  tags?: string[];
}

const { title, slug, description, link, github, tags = [] } = Astro.props;
---

<article class="border border-slate-200 dark:border-slate-800 rounded-lg p-6 hover:shadow-md dark:hover:shadow-md dark:shadow-slate-900 transition-shadow">
  <a href={`/projects/${slug}`} class="text-lg font-semibold text-slate-900 dark:text-slate-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
    {title}
  </a>

  <p class="text-slate-700 dark:text-slate-300 my-3">
    {description}
  </p>

  <div class="flex gap-3 mb-4 flex-wrap">
    {link && (
      <a href={link} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
        Visit →
      </a>
    )}
    {github && (
      <a href={github} target="_blank" rel="noopener noreferrer" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">
        GitHub →
      </a>
    )}
  </div>

  <div class="flex gap-2 flex-wrap">
    {tags.map(tag => (
      <span class="inline-block px-2 py-1 text-xs rounded bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-400">
        {tag}
      </span>
    ))}
  </div>
</article>
