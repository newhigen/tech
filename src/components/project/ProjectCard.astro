---
interface Props {
  title: string;
  slug: string;
  description: string;
  link?: string;
  github?: string;
  tags?: string[];
  period?: string;
}

const { title, slug, description, link, github, tags = [], period } = Astro.props;
---

<article style="padding: 1.25rem 0; border-bottom: 1px solid var(--border);">
  <div style="display: flex; align-items: baseline; gap: 0.75rem; margin-bottom: 0.375rem;">
    <a href={`/projects/${slug}`} style="display: block;">
      <h2 style="font-size: 1rem; font-weight: 500; color: var(--text-primary); margin: 0;">{title}</h2>
    </a>
    {period && (
      <span style="font-size: 0.75rem; color: var(--text-tertiary);">{period}</span>
    )}
  </div>
  <p style="font-size: 0.875rem; color: var(--text-secondary); margin: 0 0 0.625rem; line-height: 1.6;">
    {description}
  </p>
  <div style="display: flex; gap: 1rem; margin-bottom: 0.625rem;">
    {link && (
      <a href={link} target="_blank" rel="noopener noreferrer" style="font-size: 0.8125rem; color: var(--text-tertiary);">
        Visit →
      </a>
    )}
    {github && (
      <a href={github} target="_blank" rel="noopener noreferrer" style="font-size: 0.8125rem; color: var(--text-tertiary);">
        GitHub →
      </a>
    )}
  </div>
  {tags.length > 0 && (
    <div style="display: flex; gap: 0.375rem; flex-wrap: wrap;">
      {tags.map(tag => (
        <span style="font-size: 0.75rem; padding: 0.125rem 0.5rem; border-radius: 4px; background: var(--code-bg); color: var(--text-tertiary);">
          {tag}
        </span>
      ))}
    </div>
  )}
</article>
