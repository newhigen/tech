---
interface Props {
  title: string;
  slug: string;
  description: string;
  link?: string;
  github?: string;
  tags?: string[];
  period?: string;
  icon?: string;
}

const { title, slug, description, link, github, tags = [], period, icon } = Astro.props;
const domain = link ? new URL(link).hostname : null;
const href = `/projects/${slug}`;

function calcDuration(p?: string) {
  if (!p) return null;
  const m = p.match(/(\d{4})\.(\d{2})/);
  if (!m) return null;
  const now = new Date();
  const total = (now.getFullYear() - parseInt(m[1])) * 12 + (now.getMonth() + 1 - parseInt(m[2])) + 1;
  const n = total > 0 ? total : 1;
  if (n < 12) return `${n}개월`;
  const years = Math.floor(n / 12);
  const rem = n % 12;
  return rem === 0 ? `${years}년` : `${years}년 ${rem}개월`;
}
const duration = calcDuration(period);
---

<article class="project-card" data-href={href}>
  <div class="card-content">
    {period && (
      <p class="meta">{period}{duration ? ` (${duration})` : ''}</p>
    )}
    <h2 class="title">{title}</h2>
    <p class="description">{description}</p>
    {domain && (
      <p class="domain">
        {icon && <span class="icon">{icon}</span>}{domain}
        {github && (
          <a href={github} target="_blank" rel="noopener noreferrer" class="github-link">GitHub →</a>
        )}
      </p>
    )}
    {tags.length > 0 && (
      <div class="tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}
  </div>
  <div class="arrow" aria-hidden="true">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <line class="arrow-line" x1="2" y1="12" x2="19" y2="12" />
      <polyline class="arrow-head" points="13 6 19 12 13 18" />
    </svg>
  </div>
</article>

<script>
  import { navigate } from 'astro:transitions/client';

  document.addEventListener('click', (e) => {
    const card = (e.target as Element).closest<HTMLElement>('[data-href].project-card');
    if (!card) return;
    if ((e.target as Element).closest('a')) return;
    navigate(card.dataset.href!);
  });
</script>

<style>
  .project-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.125rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .project-card:hover {
    background-color: var(--selection);
    border-color: var(--text-tertiary);
  }

  .card-content {
    flex: 1;
    min-width: 0;
  }

  .meta {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin: 0 0 0.3rem;
    letter-spacing: 0.02em;
  }

  .title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.25rem;
    padding: 0;
    border: none;
  }

  .description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0 0 0.4rem;
    line-height: 1.5;
  }

  .domain {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    margin: 0 0 0.5rem;
  }

  .icon {
    font-size: 0.875rem;
    margin-right: 0.2rem;
  }

  .github-link {
    font-size: 0.8125rem;
    color: var(--text-tertiary);
    text-decoration: none;
    position: relative;
    z-index: 1;
  }

  .github-link:hover {
    color: var(--text-secondary);
    opacity: 1;
  }

  .tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--text-tertiary);
  }

  .arrow {
    flex-shrink: 0;
    color: var(--text-tertiary);
    display: flex;
    align-items: center;
  }

  .arrow-line {
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  .arrow-head {
    transform: translateX(5px);
    transition: transform 0.25s ease;
  }

  .project-card:hover .arrow-line {
    transform: scaleX(1);
  }

  .project-card:hover .arrow-head {
    transform: translateX(0);
  }

  .project-card:hover .arrow {
    color: var(--text-secondary);
  }
</style>
